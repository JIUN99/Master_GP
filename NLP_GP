        "\n",
        "# Text preprocessing\n",
        "stop_words = set(stopwords.words('english'))\n",
        "lemmatizer = WordNetLemmatizer()\n",
        "stemmer = PorterStemmer()\n",
        "\n",
        "def clean_text(text):\n",
        "    text = text.lower()\n",
        "    text = re.sub(r\"http\\S+|www\\S+\", '', text)\n",
        "    text = re.sub(r\"[^\\x00-\\x7F]+\", '', text)\n",
        "    text = re.sub(r\"[0-9]+\", '', text)\n",
        "    text = re.sub(f\"[{re.escape(string.punctuation)}]\", '', text)\n",
        "    tokens = text.split()\n",
        "    tokens = [w for w in tokens if w not in stop_words]\n",
        "    tokens = [lemmatizer.lemmatize(w) for w in tokens]\n",
        "    tokens = [stemmer.stem(w) for w in tokens]\n",
        "    return ' '.join(tokens)\n",
        "\n",
        "# Prediction function\n",
        "def predict_suicide(text):\n",
        "    cleaned = clean_text(text)\n",
        "    encoded = tokenizer.encode_plus(\n",
        "        cleaned,\n",
        "        add_special_tokens=True,\n",
        "        max_length=128,\n",
        "        padding='max_length',\n",
        "        truncation=True,\n",
        "        return_attention_mask=True,\n",
        "        return_tensors='tf'\n",
        "    )\n",
        "    logits = model(encoded['input_ids'], attention_mask=encoded['attention_mask']).logits\n",
        "    prob = tf.sigmoid(logits).numpy()[0][0]\n",
        "    label = \"Suicide Risk\" if prob >= 0.5 else \"Non-Suicide\"\n",
        "    return f\"{label} (Confidence: {prob:.2f})\""
