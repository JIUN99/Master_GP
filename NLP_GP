        "    # Splitting data\n",
        "    train_input_ids, val_input_ids = tf.gather(input_ids, train_idx), tf.gather(input_ids, val_idx)\n",
        "    train_masks, val_masks = tf.gather(attention_masks, train_idx), tf.gather(attention_masks, val_idx)\n",
        "    train_labels, val_labels = tf.gather(labels, train_idx), tf.gather(labels, val_idx)\n",
        "\n",
        "    # Load BERT model\n",
        "    model = TFBertForSequenceClassification.from_pretrained('bert-base-uncased', num_labels=1)  # sigmoid output\n",
