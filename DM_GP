        "# ============================================\n",
        "# CELL 19: Feature Grouping for Explainability\n",
        "# ============================================\n",
        "# Clinical, Lifestyle, Risk Flags, and Text Embeddings\n",
        "def assign_feature_group(feature):\n",
        "    if feature.startswith(\"embedding_\"):\n",
        "        return \"Transformer Text Embeddings\"\n",
        "    elif feature in [\n",
        "        \"Age\", \"BMI\", \"Blood_Pressure\", \"Cholesterol_Level\",\n",
        "        \"Triglyceride_Level\", \"Fasting_Blood_Sugar\",\n",
        "        \"CRP_Level\", \"Homocysteine_Level\", \"Sleep_Hours\"\n",
        "    ]:\n",
        "        return \"Clinical Measurements\"\n",
        "    elif feature in [\n",
        "        \"Smoking\", \"Exercise_Habits\", \"Alcohol_Consumption\",\n",
        "        \"Sugar_Consumption\", \"Stress_Level\", \"Gender\"\n",
        "    ]:\n",
        "        return \"Lifestyle / Demographic Factors\"\n",
        "    elif feature in [\n",
        "        \"High_Blood_Pressure\", \"Diabetes\", \"Low_HDL\",\n",
        "        \"High_LDL\", \"Family_Heart_Disease\"\n",
        "    ]:\n",
        "        return \"Derived Risk Flags\"\n",
        "    elif feature == \"Sentiment_Score\":\n",
        "        return \"Sentiment Feature\"\n",
        "    else:\n",
        "        return \"Other\"\n",
        "\n",
        "importance_df[\"Feature_Group\"] = importance_df[\"Feature\"].apply(assign_feature_group)\n",
        "\n",
        "group_importance = (\n",
        "    importance_df\n",
        "    .groupby(\"Feature_Group\")[\"Importance\"]\n",
        "    .sum()\n",
        "    .sort_values(ascending=False)\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "group_importance"
      ],
