      "source": [
        "# ==========================================\n",
        "# CELL 4: LLM FEATURE EXTRACTION - SENTENCE EMBEDDINGS\n",
        "# ==========================================\n",
        "\n",
        "from sentence_transformers import SentenceTransformer\n",
        "import pandas as pd\n",
        "\n",
        "# Lightweight transformer model\n",
        "embedding_model = SentenceTransformer('all-MiniLM-L6-v2')\n",
        "\n",
        "# Combine text columns\n",
        "df_hybrid['combined_text'] = (\n",
        "    df_hybrid['Patient_Questionnaire_Response'] + \" \" +\n",
        "    df_hybrid['Doctor_Triage_Note']\n",
        ")\n",
        "\n",
        "# Generate embeddings\n",
        "embeddings = embedding_model.encode(\n",
        "    df_hybrid['combined_text'].tolist(),\n",
        "    show_progress_bar=True\n",
        ")\n",
        "\n",
        "# Convert embeddings into dataframe\n",
        "embedding_df = pd.DataFrame(\n",
        "    embeddings,\n",
        "    columns=[f'embedding_{i}' for i in range(embeddings.shape[1])]\n",
        ")\n",
        "\n",
