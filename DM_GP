        "# ============================================\n",
        "# CELL 21: LLM-Assisted Model Interpretation\n",
        "# ============================================\n",
        "\n",
        "from transformers import pipeline\n",
        "import torch\n",
        "\n",
        "generator = pipeline(\n",
        "    \"text-generation\",\n",
        "    model=\"mistralai/Mistral-7B-Instruct-v0.1\",\n",
        "    torch_dtype=torch.float16,\n",
        "    device_map=\"auto\"\n",
        ")\n",
        "\n",
        "llm_prompt = f\"\"\"\n",
        "Task:\n",
        "Produce one concise, dense analytical interpretation of the model evaluation results below.\n",
        "\n",
        "Context:\n",
        "The project predicts heart disease status using synthetic multimodal patient data. The feature set includes structured clinical/lifestyle variables and LLM-generated questionnaire/triage-note text converted into transformer embeddings and sentiment features. The Transformer + NN model uses dense transformer-derived semantic representations together with structured predictors, allowing the neural network to learn nonlinear relationships across multimodal features.\n",
        "\n",
        "Evidence:\n",
        "1. Overall model performance:\n",
        "{results_df.to_string(index=False)}\n",
        "\n",
        "2. Ablation study:\n",
        "{ablation_df.to_string(index=False)}\n",
        "\n",
        "3. Grouped feature importance:\n",
        "{group_importance.to_string(index=False)}\n",
        "\n",
        "Required focus:\n",
        "- Identify the best-performing model using F1-score, Recall, and ROC-AUC.\n",
        "- Explain why the Transformer + NN performs best in this project: compare the characteristics of 4 models, emphasize Transformer NN's ability to combine structured clinical/lifestyle predictors with transformer-derived semantic text embeddings and learn nonlinear multimodal interactions.\n",
        "- Justify why Recall is prioritized over accuracy by explaining the higher clinical cost of False Negatives in healthcare screening.\n",
        "- Synthesize the ablation study to evaluate whether LLM-derived text features provide measurable predictive lift over the tabular-only baseline.\n",
        "- Critique the dominance of transformer text embeddings in the grouped feature importance results.\n",
        "- Explain the risk of target leakage, especially if the upstream text generation process encoded disease-status or risk-conditioned cues into the synthetic narratives.\n",
        "- Conclude with a balanced recommendation regarding proof-of-concept value, deployment caution, and future pipeline decoupling.\n",
        "\n",
        "Constraints:\n",
        "- Write academically in paragraph structure, implement paragraph breaks carefully, do not cover multiple points in a single paragraph.\n",
        "- Strictly maximum 300 words.\n",
        "- Do not use bullet points or numbered lists.\n",
        "- Do not invent statistics or overclaim real-world clinical validity.\n",
        "- Do not interpret individual embedding dimensions as physical clinical biomarkers.\n",
        "- Maintain a sharp, evaluative, and critical data science tone.\n",
        "\"\"\"\n",
        "\n",
        "\n",
        "def keep_complete_sentences(text):\n",
        "    # text = text.replace(\"\\n\", \" \").strip()\n",
        "\n",
        "    # If text already ends with sentence-ending punctuation, keep it\n",
        "    if text.endswith((\".\", \"!\", \"?\")):\n",
        "        return text\n",
        "\n",
        "    # Otherwise remove incomplete trailing fragment\n",
        "    last_period = max(text.rfind(\".\"), text.rfind(\"!\"), text.rfind(\"?\"))\n",
        "\n",
        "    if last_period != -1:\n",
        "        return text[:last_period + 1].strip()\n",
        "\n",
        "    return text\n",
        "\n",
        "mistral_prompt = f\"<s>[INST]\\n{llm_prompt}\\n[/INST]\"\n",
        "\n",
        "llm_output = generator(\n",
        "    mistral_prompt,\n",
        "    max_new_tokens=600,\n",
        "    do_sample=False,\n",
